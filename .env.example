# ---------- PORT ----------
PORT=3000

# ---------- NODE_ENV ----------
NODE_ENV=production

# ---------- MySQL (Railway) ----------
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASSWORD=your_password_here

# ---------- JWT ----------
# Секретный ключ должен быть длиной не менее 32 символов
JWT_SECRET=your_super_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# ---------- VK ----------
VK_COMMUNITY_TOKEN=your_vk_community_token
VK_APP_ID=your_vk_mini_app_id