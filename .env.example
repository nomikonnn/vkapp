# Настройки базы данных MySQL
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASSWORD=your_database_password_here

# Настройки сервера
PORT=3000
NODE_ENV=production

# JWT секретный ключ (сгенерируйте случайную строку)
JWT_SECRET=your_jwt_secret_key_here_generate_random_string

# VK Bot API
VK_BOT_TOKEN=your_vk_group_token_here
VK_GROUP_ID=your_vk_group_id_here

# Опционально: URL фронтенда для CORS
FRONTEND_URL=https://your-vk-app.com

# Опционально: логирование SQL запросов (development/production)
# Если установлено в 'development', будут выводиться SQL запросы
# NODE_ENV=development
